{
  "name": "wowpay",
  "version": "1.0.0",
  "description": "支付交易平台 - 易支付对接 (Cloudflare Workers + Hono)",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "wrangler d1 migrations apply wowpay-db",
    "db:migrate:create": "prisma migrate dev --create-only"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^6.6.0",
    "@prisma/client": "^6.6.0",
    "hono": "^4.7.7",
    "js-md5": "^0.8.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250424.0",
    "prisma": "^6.6.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.12.0"
  }
}
